# ─────────────────────────────────────────────────────────────────
# Dhara — Hydro-Equity Engine
# .env.example — All required environment variables
#
# Copy this file to .env (project root) and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Database ───────────────────────────────────────────────────────
# Full Neon (or local) PostgreSQL connection string.
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── JWT Authentication ─────────────────────────────────────────────
# Secret key for signing JWTs — must be long, random, and kept secret.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET

# Signing algorithm — do not change unless you know what you're doing.
ALGORITHM=HS256

# Token lifetime in hours (default: 8).
ACCESS_TOKEN_EXPIRE_HOURS=8

# ── Data Mode ──────────────────────────────────────────────────────
# Controls whether analytics use live DB or file-based outputs.
# Values: "db" (production) or "file" (fallback for demo/testing).
DATA_MODE=db

# ── CORS Allowed Origins ───────────────────────────────────────────
# Comma-separated list of frontend URLs allowed to call the API.
# For local dev: http://localhost:5500,http://localhost:8000
# For production: add your Render/Vercel frontend URL.
ALLOWED_ORIGINS=http://localhost:5500,http://localhost:8000

# ── User Seed Passwords ─────────────────────────────────────────────
# Passwords used by scripts/seed_users.py to create the 18 system users.
# Must be set before running seed_users.py — never leave these empty.

# Password for: engineer1
ENGINEER_PASSWORD=

# Password for: ward_z1 through ward_z8 (all 8 ward officers share this)
WARD_PASSWORD=

# Password for: commissioner1
COMMISSIONER_PASSWORD=

# Password for: field_op_z1 through field_op_z8 (all 8 field operators share this)
FIELD_OP_PASSWORD=
